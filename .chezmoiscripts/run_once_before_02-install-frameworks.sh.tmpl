#!/usr/bin/env bash
set -euo pipefail

# Ensure cargo bin is in PATH (tree-sitter CLI needed for nvim-treesitter parser compilation)
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Set up gpakosz/.tmux
# chezmoi handles cloning to ~/.tmux via .chezmoiexternal.toml
# We just need to create ~/.tmux.conf symlink pointing to the repo's .tmux.conf
if [ -d "$HOME/.tmux" ] && [ ! -f "$HOME/.tmux.conf" ]; then
  ln -sf "$HOME/.tmux/.tmux.conf" "$HOME/.tmux.conf"
fi

# Remove NvChad starter .git so it becomes a plain config dir
# (NvChad plugins are managed by lazy.nvim, not git)
if [ -d "$HOME/.config/nvim/.git" ]; then
  echo "Removing NvChad starter .git from ~/.config/nvim ..."
  rm -rf "$HOME/.config/nvim/.git"
fi

# Step 1: Install lazy.nvim plugins (fresh server only - skipped if already installed)
# Uses LazyDone autocmd to quit after sync completes, instead of +qa which exits immediately
if command -v nvim &>/dev/null && [ ! -d "$HOME/.local/share/nvim/lazy" ]; then
  echo "Installing NvChad plugins (first-time setup, this may take a while)..."
  nvim --headless "+Lazy! sync" -c "autocmd User LazyDone ++once qa" 2>&1 || true
fi

# Step 2: Generate NvChad base46 theme cache (skipped if already present)
# NvChad v2.5 expects cache at ~/.local/share/nvim/nvchad/base46/
# Requires plugins to be installed first (step 1 above)
if command -v nvim &>/dev/null && [ ! -d "$HOME/.local/share/nvim/nvchad/base46" ]; then
  echo "Generating NvChad base46 cache..."
  nvim --headless -c "lua require('base46').load_all_highlights()" +qa 2>&1 || true
fi
