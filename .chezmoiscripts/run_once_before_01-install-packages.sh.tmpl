#!/usr/bin/env bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew install \
  neovim \
  tmux \
  starship \
  fzf \
  fd \
  yazi \
  sesh \
  zoxide \
  direnv \
  zsh-syntax-highlighting \
  zsh-autosuggestions \
  nvm \
  glow

brew install --cask ghostty

{{ else -}}
# Linux package installation
if command -v apt-get &>/dev/null; then
  sudo apt-get update
  sudo apt-get install -y \
    fd-find \
    direnv \
    zsh \
    zsh-syntax-highlighting \
    zsh-autosuggestions \
    curl \
    git \
    build-essential \
    unzip

  # fd-find installs as fdfind on Debian/Ubuntu
  if ! command -v fd &>/dev/null && command -v fdfind &>/dev/null; then
    mkdir -p ~/.local/bin
    ln -sf "$(which fdfind)" ~/.local/bin/fd
  fi

  # Change default shell to zsh
  if [ "$SHELL" != "$(which zsh)" ]; then
    sudo chsh -s "$(which zsh)" "$USER"
  fi

elif command -v dnf &>/dev/null; then
  sudo dnf install -y \
    fd-find \
    direnv \
    zsh \
    zsh-syntax-highlighting \
    zsh-autosuggestions \
    curl \
    git

  # Change default shell to zsh
  if [ "$SHELL" != "$(which zsh)" ]; then
    sudo chsh -s "$(which zsh)" "$USER"
  fi
fi

# Install tmux only if not already present (preserves custom builds)
if ! command -v tmux &>/dev/null; then
  if command -v apt-get &>/dev/null; then
    sudo apt-get install -y tmux
  elif command -v dnf &>/dev/null; then
    sudo dnf install -y tmux
  fi
fi

# Detect architecture for binary downloads
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)          LINUX_ARCH_AMD="linux_amd64" ; LINUX_ARCH_X="x86_64"   ;;
  aarch64|arm64)   LINUX_ARCH_AMD="linux_arm64" ; LINUX_ARCH_X="arm64"    ;;
  *) echo "Warning: unknown arch $ARCH, defaulting to x86_64"
     LINUX_ARCH_AMD="linux_amd64" ; LINUX_ARCH_X="x86_64" ;;
esac

# Install fzf from GitHub releases (apt version on Ubuntu 20.04 is 0.20.0, too old for start:reload)
if [[ ! -x "$HOME/.local/bin/fzf" ]]; then
  FZF_VERSION=$(curl -s https://api.github.com/repos/junegunn/fzf/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v')
  curl -LO "https://github.com/junegunn/fzf/releases/download/v${FZF_VERSION}/fzf-${FZF_VERSION}-${LINUX_ARCH_AMD}.tar.gz"
  tar -xzf "fzf-${FZF_VERSION}-${LINUX_ARCH_AMD}.tar.gz"
  mkdir -p ~/.local/bin
  mv fzf ~/.local/bin/fzf
  rm -f "fzf-${FZF_VERSION}-${LINUX_ARCH_AMD}.tar.gz"
fi

# Install neovim (AppImage from GitHub releases, for 0.10+)
if ! command -v nvim &>/dev/null; then
  mkdir -p ~/.local/bin
  curl -LO "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-${LINUX_ARCH_X}.appimage"
  chmod +x "nvim-linux-${LINUX_ARCH_X}.appimage"
  mv "nvim-linux-${LINUX_ARCH_X}.appimage" ~/.local/bin/nvim
fi

# Install starship
if ! command -v starship &>/dev/null; then
  curl -sS https://starship.rs/install.sh | sh -s -- --yes
fi

# Install Rust if not present (required for yazi)
if ! command -v cargo &>/dev/null; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  . "$HOME/.cargo/env"
fi

# Install yazi (via cargo yazi-build)
if ! command -v yazi &>/dev/null; then
  cargo install --force yazi-build
fi

# Install zoxide
if ! command -v zoxide &>/dev/null; then
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# Install sesh (from GitHub releases)
if ! command -v sesh &>/dev/null; then
  SESH_VERSION=$(curl -s https://api.github.com/repos/joshmedeski/sesh/releases/latest | grep '"tag_name"' | cut -d'"' -f4)
  SESH_ARCH_X=$(echo "$LINUX_ARCH_X" | sed 's/arm64/aarch64/')
  curl -LO "https://github.com/joshmedeski/sesh/releases/download/${SESH_VERSION}/sesh_Linux_${SESH_ARCH_X}.tar.gz"
  tar -xzf "sesh_Linux_${SESH_ARCH_X}.tar.gz" sesh
  mkdir -p ~/.local/bin
  mv sesh ~/.local/bin/sesh
  rm -f "sesh_Linux_${SESH_ARCH_X}.tar.gz"
fi

# Install nvm (via git clone)
if [ ! -d "$HOME/.nvm" ]; then
  git clone https://github.com/nvm-sh/nvm.git "$HOME/.nvm"
  cd "$HOME/.nvm" && git checkout "$(git describe --abbrev=0 --tags --match 'v[0-9]*' "$(git rev-list --tags --max-count=1)")"
fi

# Install glow (from GitHub releases)
if ! command -v glow &>/dev/null; then
  GLOW_VERSION=$(curl -s https://api.github.com/repos/charmbracelet/glow/releases/latest | grep '"tag_name"' | cut -d'"' -f4)
  GLOW_VERSION_NUM="${GLOW_VERSION#v}"
  GLOW_ARCHIVE="glow_${GLOW_VERSION_NUM}_Linux_${LINUX_ARCH_X}"
  curl -LO "https://github.com/charmbracelet/glow/releases/download/${GLOW_VERSION}/${GLOW_ARCHIVE}.tar.gz"
  tar -xzf "${GLOW_ARCHIVE}.tar.gz" "${GLOW_ARCHIVE}/glow"
  mkdir -p ~/.local/bin
  mv "${GLOW_ARCHIVE}/glow" ~/.local/bin/glow
  rm -rf "${GLOW_ARCHIVE}" "${GLOW_ARCHIVE}.tar.gz"
fi

{{ end -}}
