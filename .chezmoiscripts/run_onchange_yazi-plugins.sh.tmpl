#!/usr/bin/env bash
# Run whenever package.toml changes
# {{ include "private_dot_config/yazi/package.toml" | sha256sum }}
set -euo pipefail

if command -v ya &>/dev/null; then
  echo "Installing/updating yazi plugins..."
  if ya help 2>&1 | grep -q "^  pkg"; then
    ya pkg install && ya pkg upgrade || true
  else
    ya pack -i || true
  fi
else
  echo "Warning: 'ya' command not found, skipping yazi plugin install"
fi
