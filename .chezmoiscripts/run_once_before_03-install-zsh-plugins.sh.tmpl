#!/usr/bin/env bash
set -euo pipefail

{{ if eq .chezmoi.os "linux" -}}
# On Linux, install zsh plugins to ~/.zsh/ if system packages are not available
ZSH_DIR="$HOME/.zsh"

if ! [ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
   ! [ -f "$ZSH_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
  echo "Installing zsh-autosuggestions..."
  mkdir -p "$ZSH_DIR"
  git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions \
    "$ZSH_DIR/zsh-autosuggestions"
fi

if ! [ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
   ! [ -f "$ZSH_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
  echo "Installing zsh-syntax-highlighting..."
  mkdir -p "$ZSH_DIR"
  git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting \
    "$ZSH_DIR/zsh-syntax-highlighting"
fi
{{ else -}}
# macOS: plugins are installed via Homebrew in step 01
echo "Skipping zsh plugin install on macOS (managed by Homebrew)"
{{ end -}}
